---
import { site } from "../../content/site";
import { nav, type Lang } from "../../content/nav";

const { currentLang = "it" } = Astro.props as { currentLang: Lang };

const primary = nav[currentLang].primary;
const services = nav[currentLang].footerServices;
const legal = nav[currentLang].legal;
const langMarker = `/${currentLang}/`;
const markerIndex = Astro.url.pathname.indexOf(langMarker);
const base = markerIndex > 0 ? Astro.url.pathname.slice(0, markerIndex) : "";
const withBase = (href: string) => {
  if (!href.startsWith("/")) return href;
  return `${base}${href}`;
};

const heading = {
  services: currentLang === "de" ? "Leistungen" : "Servizi",
  navigation: currentLang === "de" ? "Navigation" : "Navigazione",
  contact: currentLang === "de" ? "Kontakt" : "Contatti",
  area: currentLang === "de" ? "Einsatzgebiet" : "Zona servita",
};
---

<footer class="border-t border-zinc-200/70 bg-white/50 dark:border-zinc-800/70 dark:bg-zinc-950/40">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="space-y-2">
        <div class="flex items-center gap-2 font-semibold">
          <span class="inline-block h-2 w-2 rounded-full bg-zinc-900 dark:bg-white"></span>
          {site.brand}
        </div>
        <p class="text-sm text-zinc-600 dark:text-zinc-400">
          {currentLang === "de"
            ? "Klimaanlagen & Heizungsservice in Meran und im Burggrafenamt."
            : "Climatizzatori e assistenza caldaie a Merano e in Burgraviato."}
        </p>
      </div>

      <div>
        <p class="text-sm font-semibold">{heading.navigation}</p>
        <ul class="mt-3 space-y-2">
          {primary.map((i) => (
            <li>
              <a class="text-sm text-zinc-700 hover:underline dark:text-zinc-300" href={withBase(i.href)}>
                {i.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-sm font-semibold">{heading.services}</p>
        <ul class="mt-3 space-y-2">
          {services.map((i) => (
            <li>
              <a class="text-sm text-zinc-700 hover:underline dark:text-zinc-300" href={withBase(i.href)}>
                {i.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="space-y-3">
        <p class="text-sm font-semibold">{heading.contact}</p>

        <a
          href={site.phoneHref}
          class="inline-flex w-full items-center justify-center rounded-xl bg-zinc-900 px-4 py-3 text-sm font-semibold text-white transition hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
        >
          {currentLang === "de" ? "Anrufen" : "Chiama"}: {site.phoneDisplay}
        </a>

        <div class="text-sm text-zinc-600 dark:text-zinc-400">
          <p class="font-semibold">{heading.area}</p>
          <p>
            {currentLang === "de"
              ? "Meran, Algund, Dorf Tirol, Schenna, Marling, Lana, Tscherms, Naturns & Umgebung."
              : "Merano, Lagundo, Tirolo, Scena, Marlengo, Lana, Cermes, Naturno e dintorni."}
          </p>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-zinc-200/70 pt-6 text-xs text-zinc-600 dark:border-zinc-800/70 dark:text-zinc-400 sm:flex-row sm:items-center sm:justify-between">
      <p>© {new Date().getFullYear()} {site.brand}</p>
      <div class="flex flex-wrap gap-x-4 gap-y-2">
        {legal.map((i) => (
          <a class="hover:underline" href={withBase(i.href)}>{i.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
