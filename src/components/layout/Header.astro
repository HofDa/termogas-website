---
import { site } from "../../content/site";
import { nav, type Lang } from "../../content/nav";
import { getLocalizedPath } from "../../lib/hreflang";

const { currentLang = "it", currentPath = "/it/" } = Astro.props as {
  currentLang: Lang;
  currentPath: string;
};

const itHref = getLocalizedPath(currentPath, "it");
const deHref = getLocalizedPath(currentPath, "de");

const items = nav[currentLang].primary;
---

<header class="sticky top-0 z-50 border-b border-zinc-200/70 bg-white/70 backdrop-blur dark:border-zinc-800/70 dark:bg-zinc-950/60">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3">
    <!-- Brand -->
    <a href={`/${currentLang}/`} class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="inline-block h-2 w-2 rounded-full bg-zinc-900 dark:bg-white"></span>
      {site.brand}
      <span class="hidden text-sm font-normal text-zinc-600 dark:text-zinc-400 sm:inline">
        {site.area}
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Hauptnavigation">
      {items.map((i) => (
        <a
          href={i.href}
          class="rounded-xl px-3 py-2 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100 dark:text-zinc-200 dark:hover:bg-zinc-900/50"
        >
          {i.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <!-- Language switch (always visible) -->
      <div class="inline-flex overflow-hidden rounded-full border border-zinc-200 dark:border-zinc-800">
        <a
          href={itHref}
          data-lang="it"
          class={`px-3 py-2 text-sm font-semibold transition ${
            currentLang === "it"
              ? "bg-zinc-900 text-white dark:bg-white dark:text-zinc-900"
              : "text-zinc-700 hover:bg-zinc-100 dark:text-zinc-200 dark:hover:bg-zinc-900/50"
          }`}
          aria-label="Italiano"
        >IT</a>
        <a
          href={deHref}
          data-lang="de"
          class={`px-3 py-2 text-sm font-semibold transition ${
            currentLang === "de"
              ? "bg-zinc-900 text-white dark:bg-white dark:text-zinc-900"
              : "text-zinc-700 hover:bg-zinc-100 dark:text-zinc-200 dark:hover:bg-zinc-900/50"
          }`}
          aria-label="Deutsch"
        >DE</a>
      </div>

      <!-- Phone CTA -->
      <a
        href={site.phoneHref}
        class="hidden rounded-xl border border-zinc-300 bg-white/60 px-4 py-2 text-sm font-semibold text-zinc-900 shadow-sm backdrop-blur transition hover:bg-white dark:border-zinc-700 dark:bg-zinc-900/40 dark:text-zinc-100 dark:hover:bg-zinc-900 md:inline-flex"
      >
        {currentLang === "de" ? "Anrufen" : "Chiama"}
      </a>

      <!-- Mobile menu button -->
      <button
        id="menuBtn"
        type="button"
        class="inline-flex items-center justify-center rounded-xl border border-zinc-200 bg-white/60 p-2 text-sm font-semibold text-zinc-900 shadow-sm backdrop-blur transition hover:bg-white dark:border-zinc-800 dark:bg-zinc-900/40 dark:text-zinc-100 dark:hover:bg-zinc-900 md:hidden"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobileNav"
      >
        ☰
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobileNav" class="hidden border-t border-zinc-200/70 dark:border-zinc-800/70 md:hidden">
    <div class="mx-auto max-w-6xl px-4 py-3">
      <nav class="grid gap-2" aria-label="Mobile Navigation">
        {items.map((i) => (
          <a
            href={i.href}
            class="rounded-xl px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-100 dark:text-zinc-100 dark:hover:bg-zinc-900/50"
          >
            {i.label}
          </a>
        ))}
        <a
          href={site.phoneHref}
          class="mt-2 rounded-xl bg-zinc-900 px-3 py-3 text-center text-sm font-semibold text-white transition hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
        >
          {currentLang === "de" ? "Jetzt anrufen" : "Chiama ora"}
        </a>
      </nav>
    </div>
  </div>

  <script is:inline>
    (() => {
      // save language override
      document.querySelectorAll("a[data-lang]").forEach((a) => {
        a.addEventListener("click", () => {
          try {
            const lang = a.getAttribute("data-lang");
            if (lang === "it" || lang === "de") localStorage.setItem("lang", lang);
          } catch {}
        });
      });

      // mobile menu toggle
      const btn = document.getElementById("menuBtn");
      const panel = document.getElementById("mobileNav");
      if (!btn || !panel) return;

      btn.addEventListener("click", () => {
        const isHidden = panel.classList.toggle("hidden") === false; // false => now visible
        btn.setAttribute("aria-expanded", String(isHidden));
      });
    })();
  </script>
</header>
