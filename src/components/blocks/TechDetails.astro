---
import Section from "./Section.astro";

const {
  id = "technik",
  title = "Technik",
  items = [],
} = Astro.props as {
  id?: string;
  title?: string;
  items: Array<{ title: string; text: string }>;
};
---

<Section id={id} title={title}>
  <div class="grid gap-4 md:grid-cols-3">
    {items.map((item) => (
      <div class="card">
        <h3 class="h3">{item.title}</h3>
        <p class="mt-3 copy">{item.text}</p>
      </div>
    ))}
  </div>
</Section>
