---
import Section from "./Section.astro";

type Lang = "de" | "it";

const {
  lang = "de",
  id = "ablauf",
  title,
  subtitle,
  steps = [],
} = Astro.props as {
  lang?: Lang;
  id?: string;
  title?: string;
  subtitle?: string;
  steps: Array<{ title: string; text: string }>;
};

const copy = {
  de: { title: "Ablauf", subtitle: "So laeuft die Anfrage bis zur Umsetzung ab.", step: "Schritt" },
  it: { title: "Come lavoriamo", subtitle: "Dalla richiesta al lavoro eseguito, il percorso e questo.", step: "Passo" },
} as const;

const ui = copy[lang];
---

<Section id={id} title={title ?? ui.title} subtitle={subtitle ?? ui.subtitle}>
  <div class="grid gap-4 md:grid-cols-3">
    {steps.map((step, index) => (
      <div class="card">
        <p class="kicker">{ui.step} {index + 1}</p>
        <h3 class="mt-2 h3">{step.title}</h3>
        <p class="mt-3 copy">{step.text}</p>
      </div>
    ))}
  </div>
</Section>
