<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,follow" />
    <title>TERMOgas</title>

    <script is:inline>
      (() => {
        const base = (document.querySelector('meta[name="astro-base"]')?.getAttribute("content") || "").replace(/\/$/, "");
        const toLocalizedPath = (lang) => `${base}/${lang}/`.replace(/\/+/g, "/");

        try {
          const saved = localStorage.getItem("lang");
          if (saved === "it" || saved === "de") {
            window.location.replace(toLocalizedPath(saved));
            return;
          }

          const lang = (navigator.language || "").toLowerCase();
          if (lang.startsWith("de")) window.location.replace(toLocalizedPath("de"));
          else window.location.replace(toLocalizedPath("it"));
        } catch {
          window.location.replace(toLocalizedPath("it"));
        }
      })();
    </script>
  </head>
  <body></body>
</html>
