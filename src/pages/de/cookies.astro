---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";

const meta = {
  title: "Cookies | TERMOgas Meran",
  description: "Cookie-Informationen von TERMOgas – technisch notwendige Cookies und Einwilligungen.",
  canonicalPath: "/de/cookies/",
  lang: "de",
};
---

<BaseLayout {...meta}>
  <Header currentLang="de" currentPath="/de/cookies/" />
  <main class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="text-3xl font-semibold tracking-tight">Cookies</h1>
    <p class="mt-3 text-zinc-700 dark:text-zinc-300">
      Platzhalterseite. Hier werden Cookie-Kategorien, Laufzeiten, Zwecke und Einwilligungsoptionen beschrieben.
    </p>

    <div class="mt-6 rounded-2xl border border-zinc-200 bg-white/60 p-5 backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/40">
      <p class="text-sm font-semibold">Technisch notwendige Cookies</p>
      <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
        Diese sind für Kernfunktionen erforderlich (z. B. Spracheinstellung). Tracking nur bei Einwilligung.
      </p>
    </div>
  </main>
  <Footer currentLang="de" />
</BaseLayout>