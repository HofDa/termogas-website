---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import CTA from "../../components/blocks/CTA.astro";
import content from "../../data/it/contatti";
import { buildMeta } from "../../lib/seo";

const meta = buildMeta({
  title: content.meta.title,
  description: content.meta.description,
  canonicalPath: "/it/contatti/",
  lang: "it",
});
---

<BaseLayout {...meta}>
  <Header currentLang="it" currentPath="/it/contatti/" />
  <main class="section-loose">
    <div class="container-page stack-4">
      <p class="kicker">{content.intro.eyebrow}</p>
      <h1 class="h1">{content.intro.title}</h1>
      <p class="lead measure">{content.intro.subtitle}</p>
    </div>
    <CTA
      lang="it"
      id={content.cta.id}
      title={content.cta.title}
      subtitle={content.cta.subtitle}
      primaryLabel={content.cta.primaryLabel}
      phoneLabel={content.cta.phoneLabel}
    />
  </main>
  <Footer currentLang="it" />
</BaseLayout>
