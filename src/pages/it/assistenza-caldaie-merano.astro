---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import PageSections from "../../components/PageSections.astro";
import { buildSchemaGraph } from "../../lib/schema";
import content from "../../data/it/caldaie";

const meta = {
  title: content.meta.title,
  description: content.meta.description,
  canonicalPath: "/it/assistenza-caldaie-merano/",
  lang: "it",
  schemaGraph: buildSchemaGraph({
    lang: "it",
    service: {
      urlPath: "/it/assistenza-caldaie-merano/",
      name: "Assistenza caldaie a Merano",
      description:
        "Manutenzione e assistenza caldaie a Merano e in Burgraviato per sicurezza, continuita di esercizio ed efficienza.",
      areaServed: ["Merano", "Burgraviato"],
    },
  }),
};
---

<BaseLayout {...meta}>
  <Header currentLang="it" currentPath="/it/assistenza-caldaie-merano/" />
  <main>
    <PageSections content={content} lang="it" />
  </main>
  <Footer currentLang="it" />
</BaseLayout>
