---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";

const meta = {
  title: "Note legali | TERMOgas Merano",
  description: "Note legali TERMOgas – climatizzatori e assistenza caldaie a Merano e in Burgraviato.",
  canonicalPath: "/it/impressum/",
  lang: "it",
};
---

<BaseLayout {...meta}>
  <Header currentLang="it" currentPath="/it/impressum/" />
  <main class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="text-3xl font-semibold tracking-tight">Note legali</h1>
    <p class="mt-3 text-zinc-700 dark:text-zinc-300">
      Pagina segnaposto. Qui inseriremo i dati legali dell'azienda (ragione sociale, sede, P. IVA, contatti, note).
    </p>
  </main>
  <Footer currentLang="it" />
</BaseLayout>
