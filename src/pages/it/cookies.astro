---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";

const meta = {
  title: "Cookie | TERMOgas Merano",
  description: "Informativa cookie TERMOgas – cookie tecnici, preferenze e consenso.",
  canonicalPath: "/it/cookies/",
  lang: "it",
};
---

<BaseLayout {...meta}>
  <Header currentLang="it" currentPath="/it/cookies/" />
  <main class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="text-3xl font-semibold tracking-tight">Cookie</h1>
    <p class="mt-3 text-zinc-700 dark:text-zinc-300">
      Pagina segnaposto. Qui spiegheremo categorie di cookie, durata, finalità e opzioni di consenso.
    </p>

    <div class="mt-6 rounded-2xl border border-zinc-200 bg-white/60 p-5 backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/40">
      <p class="text-sm font-semibold">Cookie tecnici</p>
      <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
        Necessari per funzioni base (ad es. preferenza lingua). Cookie di tracciamento solo con consenso.
      </p>
    </div>
  </main>
  <Footer currentLang="it" />
</BaseLayout>
